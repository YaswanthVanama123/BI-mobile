{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "allowJs": true,
    "jsx": "react-native"
  },
  "include": ["src", "index.js"],
  "exclude": ["node_modules", "android", "ios"]
}
